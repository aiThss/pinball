# Production environment — copy sang .env.production và điền giá trị thật
# KHÔNG commit file này vào git

MONGODB_URI=mongodb://mongo:27017/pinball
NEXT_PUBLIC_APP_URL=https://your-domain.com
ADMIN_PASSWORD=change-me-strong-password
STAFF_ACCESS_KEY=change-me-staff-key

# VAPID keys cho Web Push (generate bằng: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)")
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@your-domain.com

# Expose cho browser (phải có prefix NEXT_PUBLIC_)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Telegram Bot Webhook URL (Dokploy bot URL)
# VD: https://bot.babyress.games/webhook/pinball
TELEGRAM_BOT_WEBHOOK_URL=your-bot-domain-webhook-url
